{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Disabled Packages",
      // 统一使用 /owner/repo/ 正则写法：
      // - 带首尾斜杠：Renovate 按正则匹配 packageName，适合忽略 registry/domain 前缀差异
      // - 不带斜杠：Renovate 按完整 packageName 精确匹配，仅在必须精确命中时使用
      matchPackageNames: [
        "/rook/",
        "/homarr-labs/",
        "/netbirdio/",

        "/toeverything/affine/", // affine
        "/amir20/dozzle/", // dozzle
        "/glanceapp/glance/", // glance
        "/immich-app/", // immich
        "/zxh326/kite/", // kite
        "/karakeep-app/karakeep/", // karakeep
        "/getmeili/meilisearch/", // karakeep
        "/zenika/alpine-chrome/", // karakeep
        "/librespeed/speedtest-rust/", // librespeed
        "/n8n-io/", // n8n
        "/calciumion/new-api/", // new-api
        "/ollama/ollama/", // ollama
        "/open-webui/open-webui/", // ollama-web
        "/linuxserver/mariadb/", // seafile-db
        "/seafileltd/", // seafile
        "/yourselfhosted/slash/", // slash
        "/dani-garcia/vaultwarden/", // vaultwarden
      ],
      enabled: false
    },
    {
      description: "CLIProxyAPI sourceUrl 补充",
      matchPackageNames: ["/cli-proxy-api/"],
      sourceUrl: "https://github.com/router-for-me/CLIProxyAPI"
    },
    {
      description: "Ollama sourceUrl 补充",
      matchPackageNames: ["/ollama/ollama/"],
      sourceUrl: "https://github.com/ollama/ollama"
    },
    {
      description: "docker-proxy 补充",
      matchPackageNames: ["/tecnativa/docker-socket-proxy/"],
      sourceUrl: "https://github.com/Tecnativa/docker-socket-proxy"
    },
    {
      description: "derper 补充",
      matchPackageNames: ["/kaaanata/derper-docker/"],
      sourceUrl: "https://github.com/kaaanata/derper-docker"
    },
    {
      description: "anubis 补充",
      matchPackageNames: ["/techarohq/anubis/"],
      sourceUrl: "https://github.com/TecharoHQ/anubis"
    },
    {
      description: "prompp 补充",
      matchPackageNames: ["/prompp/prompp/"],
      sourceUrl: "https://github.com/deckhouse/prompp"
    },
    {
      description: "envoy 补充",
      matchPackageNames: ["/envoyproxy/envoy/"],
      sourceUrl: "https://github.com/envoyproxy/envoy"
    },
    {
      description: "seafile changelog 补充",
      matchPackageNames: [
        "/seafileltd/"
      ],
      changelogUrl: "https://manual.seafile.com/{{{newMajor}}}.0/changelog/server-changelog/"
    },
  ],
}
